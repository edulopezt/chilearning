# ================================================================
# Chilearning — Plantilla de variables de entorno (.env.example)
#
# USO: copia este archivo a `.env.local` y completa los valores.
# ⚠️ NUNCA commitear .env.local ni pegar claves reales en chats.
# Este archivo (la plantilla, con valores falsos) SÍ se commitea.
#
# Etiquetas: [H0] = necesario para el Hito 0 (esta semana)
#            [H1+]/[H3]/[H5] = puede esperar a ese hito
# ================================================================

# ---------- App [H0] ----------
NODE_ENV=development
APP_ENV=development                  # development | staging | production
APP_BASE_URL=http://localhost:3000
# Dominio raíz para subdominios de tenant en desarrollo:
# *.localtest.me resuelve solo a 127.0.0.1 → demo.localtest.me:3000 funciona sin tocar hosts.
TENANT_ROOT_DOMAIN=localtest.me

# ---------- Supabase [H0] ----------
# Crear proyecto en https://supabase.com → región São Paulo (sa-east-1), plan Free para dev.
# Valores en: Dashboard → Settings → API  (en proyectos nuevos las llaves pueden
# llamarse "publishable" y "secret" en vez de "anon" y "service_role" — son equivalentes).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=CAMBIAME_llave_publica
SUPABASE_SERVICE_ROLE_KEY=CAMBIAME_llave_secreta   # ⚠️ SOLO server (worker/callbacks); jamás al navegador
SUPABASE_DB_PASSWORD=CAMBIAME                      # la defines al crear el proyecto
SUPABASE_PROJECT_REF=abcdefghijklmnop              # id del proyecto (URL del dashboard), para `supabase link`
SUPABASE_ACCESS_TOKEN=sbp_CAMBIAME                 # https://supabase.com/dashboard/account/tokens (para el CLI)

# ---------- Redis / colas [H2] ----------
# Dev: `docker run -d --name chilearning-redis-dev -p 6379:6379 redis:7-alpine`.
# Staging/prod: servicio Redis en Coolify. Lo usa SOLO el worker (`pnpm worker`).
REDIS_URL=redis://localhost:6379
# Frecuencia del tick del worker (ms). Default: 300000 (5 min).
#SENCE_TICK_EVERY_MS=300000

# ---------- Cifrado de tokens SENCE por tenant [H0] ----------
# Generar con:  openssl rand -base64 32
SENCE_TOKEN_ENCRYPTION_KEY=CAMBIAME_openssl_rand_base64_32

# ---------- SENCE (RCE) [H0 usa SOLO el mock] ----------
SENCE_ENV=mock                       # mock | test | prod — jamás hardcodear en código
SENCE_MOCK_URL=http://localhost:4010
# Timing operativo del motor/worker (I-13, D-003) — defaults del contrato; solo
# descomentar para desviarse. Valores inválidos caen al default con warning.
#SENCE_SESSION_MAX_HOURS=3           # ventana de sesión (T2 ancla expires_at)
#SENCE_PENDING_TIMEOUT_MINUTES=60    # abandono de Clave Única (T4)
# Alerta de tasa de error SENCE (worker, task 2.6):
#SENCE_ALERT_WINDOW_MINUTES=60       # ventana de cálculo (y cooldown)
#SENCE_ALERT_ERROR_RATE_THRESHOLD=0.2  # umbral 0..1, borde inclusivo
#SENCE_ALERT_MIN_EVENTS=5            # mínimo de callbacks para evaluar
# Alerta de asistencia baja el día 1 (worker, task 2.7):
#SENCE_DAY1_ATTENDANCE_THRESHOLD=0.5 # alerta si ratio < umbral (exclusivo)
#SENCE_DAY1_EVAL_HOUR=13             # hora local Chile desde la que se evalúa
# ⚠️ IMPORTANTE: el token real del OTEC NO va en este archivo ni en el repo.
#    Se ingresa por la UI de administración y se guarda CIFRADO por tenant (HU-5.4).
#    El ambiente `test` (rcetest) se usa solo en sesión supervisada (tarea 0.9);
#    el turno nocturno autónomo trabaja únicamente contra el mock.

# ---------- Seeds de desarrollo [H0] ----------
SEED_SUPERADMIN_EMAIL=hola@edulopezt.com
SEED_DEMO_TENANT_SLUG=demo

# ---------- Correo transaccional [H2 — decidido: Resend] ----------
# https://resend.com → API Keys (capa gratuita sirve para partir).
# Requiere verificar el dominio (registros DNS). SIN key, el código degrada a
# no-op: las inscripciones no se bloquean, los correos quedan como "skipped".
RESEND_API_KEY=re_CAMBIAME
MAIL_FROM="Chilearning <no-responder@TU-DOMINIO.cl>"
# Destinatario de las alertas operativas del worker (tasa de error SENCE, día-1).
ALERT_EMAIL_TO=hola@edulopezt.com

# ---------- Video [H1] ----------
# https://bunny.net → Stream → tu Video Library → API
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=vz-xxxxxx.b-cdn.net

# ---------- Seguridad / 2FA [H3] ----------
# Enforcement de 2FA (task 3.6): off | enroll | enforce. Default off.
# `enforce` exige AAL2 a superadmin/otec_admin. Requiere Supabase Pro en el cloud.
MFA_ENFORCEMENT=off

# ---------- Observabilidad [H1] ----------
# https://sentry.io → proyecto Next.js (free tier)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                   # solo CI, para subir sourcemaps

# ---------- Backups off-site [H3] ----------
# Cloudflare R2 (S3 compatible): dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=faro-backups

# ---------- n8n [H3] ----------
# Se despliega en Coolify; la app le avisa por webhook firmado.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=                  # openssl rand -hex 32

# ---------- WhatsApp (Meta Cloud API) [H5] ----------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ---------- IA (Tutor + lotes) [H5] ----------
# https://console.anthropic.com → API Keys. No se usa antes del Hito 5.
ANTHROPIC_API_KEY=
AI_MONTHLY_TOKEN_BUDGET_DEFAULT=1000000
