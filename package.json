{
  "name": "chilearning",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:rls && pnpm test:integration",
    "test:unit": "vitest run --project unit",
    "test:rls": "vitest run --project rls",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "sence:mock": "node tools/sence-mock/server.ts",
    "build:worker": "esbuild src/worker/index.ts --bundle --platform=node --target=node24 --outfile=dist/worker/index.js --sourcemap --log-level=warning",
    "worker": "pnpm build:worker && node --env-file-if-exists=.env.local dist/worker/index.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@sentry/nextjs": "^10.65.0",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.3",
    "bullmq": "^5.80.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^4.5.7",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "next": "16.2.10",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "scorm-again": "^3.1.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jose": "^6.2.3",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
